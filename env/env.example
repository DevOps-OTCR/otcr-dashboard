# ============================================================================
# PRODUCTION ENVIRONMENT CONFIGURATION
# ============================================================================
# Copy this file to ../.env.production and fill in your production values
# NEVER commit .env.production to git!
# ============================================================================

# ============================================================================
# FRONTEND ENVIRONMENT (Next.js)
# ============================================================================
# Authentication
NEXT_PUBLIC_MSAL_CLIENT_ID=...
NEXT_PUBLIC_MSAL_AUTHORITY=https://login.microsoftonline.com/<tenant-id>
NEXT_PUBLIC_MSAL_REDIRECT_URI=http://localhost:3000/auth/callback
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXTAUTH_URL=http://localhost:3000

#Google Calendar
NEXT_PUBLIC_GOOGLE_CALENDAR_EMBED_URL=


# ============================================================================
# BACKEND ENVIRONMENT (NestJS)
# ============================================================================

# DATABASE
# DATABASE_URL can use a pooled/transaction endpoint for normal app traffic.
DATABASE_URL=postgresql://user:password@pooler-host:6543/otcr_dashboard?schema=public
# DIRECT_URL should use the direct Postgres host for Prisma schema commands like db push/migrate.
DIRECT_URL=postgresql://user:password@direct-host:5432/otcr_dashboard?schema=public

# REDIS (Production instance)
REDIS_HOST=your-production-redis-host
REDIS_PORT=6379
REDIS_URL=redis://your-production-redis-host:6379
# If using Redis Cloud or managed service:
# REDIS_URL=rediss://default:password@your-redis-host:port

# NOTIFICATIONS
SLACK_CLIENT_ID=""
SLACK_CLIENT_SECRET=""
SLACK_REDIRECT_URI="http://localhost:4000/integrations/slack/oauth/callback"
SLACK_SCOPES="chat:write,im:write,users:read,users:read.email"
SLACK_BOT_TOKEN_ENCRYPTION_KEY=""


# APPLICATION
PORT=4000
NODE_ENV=production
FRONTEND_URL=https://yourdomain.com
