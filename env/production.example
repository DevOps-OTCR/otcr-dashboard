# ============================================================================
# PRODUCTION ENVIRONMENT CONFIGURATION
# ============================================================================
# Copy this file to ../.env.production and fill in your production values
# NEVER commit .env.production to git!
# ============================================================================

# ============================================================================
# FRONTEND ENVIRONMENT (Next.js)
# ============================================================================
# Authentication
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=generate_a_random_secret_here
NEXT_PUBLIC_API_URL=http://localhost:4000
# ============================================================================
# BACKEND ENVIRONMENT (NestJS)
# ============================================================================

# DATABASE - Use your production database URL
DATABASE_URL=postgresql://user:password@production-host:5432/otcr_dashboard?schema=public

# REDIS (Production instance)
REDIS_HOST=your-production-redis-host
REDIS_PORT=6379
REDIS_URL=redis://your-production-redis-host:6379
# If using Redis Cloud or managed service:
# REDIS_URL=rediss://default:password@your-redis-host:port

# NOTIFICATIONS
SLACK_CLIENT_ID=""
SLACK_CLIENT_SECRET=""
SLACK_REDIRECT_URI="http://localhost:4000/integrations/slack/oauth/callback"
SLACK_SCOPES="chat:write,im:write,users:read.email"
SLACK_BOT_TOKEN_ENCRYPTION_KEY=""


# APPLICATION
PORT=4000
NODE_ENV=production
FRONTEND_URL=https://yourdomain.com


# ============================================================================
# SECURITY
# ============================================================================
# Add these for enhanced security in production
SESSION_SECRET=generate_a_strong_random_secret_here
CORS_ORIGIN=https://yourdomain.com

# ============================================================================
# MONITORING & LOGGING (Optional but recommended)
# ============================================================================
# SENTRY_DSN=your_sentry_dsn
# LOG_LEVEL=info
# APM_SERVER_URL=your_apm_server
