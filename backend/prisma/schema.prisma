generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

model applications {
  id                 Int               @id @default(autoincrement())
  name               String            @db.VarChar(255)
  email              String            @db.VarChar(255)
  interest           String?           @db.VarChar(500)
  resume_filename    String?           @db.VarChar(255)
  resume_path        String?           @db.VarChar(500)
  status             String            @default("pending") @db.VarChar(20)
  created_at         DateTime          @default(now()) @db.Timestamp(6)
  reviewed_at        DateTime?         @db.Timestamp(6)
  notes              String?
  archived_at        DateTime?         @db.Timestamp(6)
  assessment_link_id Int?
  assessment_links   assessment_links? @relation(fields: [assessment_link_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([assessment_link_id], map: "ix_applications_assessment_link_id")
  @@index([email], map: "ix_applications_email")
}

model assessment_links {
  id           Int            @id @default(autoincrement())
  token        String         @unique @db.VarChar(64)
  email        String?        @db.VarChar(255)
  label        String?        @db.VarChar(255)
  created_at   DateTime       @default(now()) @db.Timestamp(6)
  expires_at   DateTime?      @db.Timestamp(6)
  applications applications[]
  attempts     attempts[]

  @@index([email], map: "ix_assessment_links_email")
  @@index([token], map: "ix_assessment_links_token")
}

model assessment_progress_snapshots {
  id                 Int      @id @default(autoincrement())
  attempt_id         Int
  snapshot_at        DateTime @db.Timestamp(6)
  sections_completed Json?    @db.Json
  current_section    String?  @db.VarChar(50)
  elapsed_seconds    Int
  progress_detail    Json?
  attempts           attempts @relation(fields: [attempt_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([attempt_id], map: "ix_assessment_progress_snapshots_attempt_id")
  @@index([id], map: "ix_assessment_progress_snapshots_id")
}

model attempts {
  id                            Int                             @id @default(autoincrement())
  link_id                       Int
  started_at                    DateTime                        @default(now()) @db.Timestamp(6)
  last_activity_at              DateTime                        @default(now()) @db.Timestamp(6)
  completed_at                  DateTime?                       @db.Timestamp(6)
  sections_completed            Json?                           @default("[]")
  focus_loss_events             Int?                            @default(0)
  is_flagged                    Boolean?                        @default(false)
  integrity_notes               String?                         @db.VarChar(500)
  assessment_progress_snapshots assessment_progress_snapshots[]
  assessment_links              assessment_links                @relation(fields: [link_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  submissions                   submissions[]

  @@index([link_id], map: "ix_attempts_link_id")
}

model submissions {
  id            Int      @id @default(autoincrement())
  attempt_id    Int
  section       String   @db.VarChar(50)
  payload       Json
  coding_result Json?
  notes         String?  @db.VarChar(500)
  submitted_at  DateTime @default(now()) @db.Timestamp(6)
  attempts      attempts @relation(fields: [attempt_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([attempt_id], map: "ix_submissions_attempt_id")
}


// OTCR Dashboard - Complete Database Schema
// Defines all entities for project management, deliverables, notifications


// ============================================================================
// USERS & AUTHENTICATION
// ============================================================================

model User {
  id        String   @id @default(cuid())
  googleId  String?  @unique
  email     String   @unique
  firstName String?
  lastName  String?
  role      Role     @default(CONSULTANT)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  accounts           Account[]
  sessions           Session[]
  pmProjects         Project[]        @relation("ProjectPM")
  projectAssignments ProjectMember[]
  submissions        Submission[]
  extensionRequests  Extension[]      @relation("ExtensionRequester")
  extensionReviews   Extension[]      @relation("ExtensionReviewer")
  submissionReviews  Submission[]     @relation("SubmissionReviewer")
  timeEntries        TimeEntry[]
  notifications      Notification[]
  tasksCreated       Task[]
  assignedDeliverables Deliverable[] @relation("DeliverableAssignee")
  deliverableAssignments DeliverableAssignment[]
  assignedDeliverableSubtasks DeliverableSubtask[] @relation("DeliverableSubtaskAssignee")
  slackOAuthStates   SlackOAuthState[]
  slackConnections   SlackUserConnection[]
  installedWorkspaces SlackWorkspace[] @relation("SlackWorkspaceInstaller")
  reviewedOnboardingRequests OnboardingRequest[] @relation("OnboardingReviewer")
  feedbackSubmissions FeedbackSubmission[]
  attendanceEventsCreated AttendanceEvent[] @relation("AttendanceEventCreator")
  attendanceCheckIns AttendanceCheckIn[]
  attendanceAvailabilitySelections AttendanceEventAvailabilitySelection[]
  when2MeetPollsCreated When2MeetPoll[]          @relation("When2MeetPollCreator")
  when2MeetAvailabilities When2MeetAvailability[]

  @@index([googleId])
  @@index([email])
  @@index([role])
}

model OnboardingRequest {
  id             String                  @id @default(cuid())
  name           String
  email          String                  @unique
  requestedRole  Role
  status         OnboardingRequestStatus @default(PENDING)
  reviewedById   String?
  reviewedAt     DateTime?
  reviewerNotes  String?
  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt

  reviewer User? @relation("OnboardingReviewer", fields: [reviewedById], references: [id])

  @@index([status])
  @@index([email])
  @@index([createdAt])
}

model FeedbackSubmission {
  id             String   @id @default(cuid())
  formType       String   @default("DASHBOARD_FEEDBACK")
  problem        String?
  description    String
  urgency        String?
  contactName    String?
  contactEmail   String?
  submitterId    String?
  submitterEmail String?
  submitterName  String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  submitter User? @relation(fields: [submitterId], references: [id], onDelete: SetNull)

  @@index([submitterId])
  @@index([createdAt])
  @@index([formType, createdAt])
}

enum Role {
  ADMIN
  PM
  LC
  PARTNER
  EXECUTIVE
  CONSULTANT
}

enum OnboardingRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

model AllowedEmail {
  id        String   @id @default(cuid())
  email     String   @unique
  role      Role?    // Optional role assignment for the email
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
  @@index([active])
}

// ============================================================================
// PROJECTS
// ============================================================================

model Project {
  id          String        @id @default(cuid())
  name        String
  description String?
  clientName  String?
  googleCalendarId String?
  pmId        String
  startDate   DateTime
  endDate     DateTime?
  status      ProjectStatus @default(ACTIVE)
  sprintStartDay     Weekday @default(MONDAY)
  initialSlideDueDay Weekday @default(TUESDAY)
  finalSlideDueDay   Weekday @default(THURSDAY)
  defaultDueTime     String  @default("23:59")
  sprintTimezone     String  @default("America/Chicago")
  autoGenerateSprints Boolean @default(true)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  pm           User            @relation("ProjectPM", fields: [pmId], references: [id])
  members      ProjectMember[]
  deliverables Deliverable[]
  sprints      Sprint[]
  attendanceEvents AttendanceEvent[]
  calendarSetting ProjectCalendarSetting?
  when2MeetPolls When2MeetPoll[]

  @@index([pmId])
  @@index([status])
  @@index([startDate])
}

enum ProjectStatus {
  ACTIVE
  COMPLETED
  ON_HOLD
  CANCELLED
}

enum Weekday {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

model ProjectMember {
  id        String    @id @default(cuid())
  projectId String
  userId    String
  joinedAt  DateTime  @default(now())
  leftAt    DateTime?

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id])

  @@unique([projectId, userId])
  @@index([projectId])
  @@index([userId])
}

model AttendanceEvent {
  id                   String                  @id @default(cuid())
  title                String
  eventDate            DateTime
  locationType         AttendanceLocationType
  locationLabel        String?
  latitude             Float?
  longitude            Float?
  geofenceRadiusMeters Int                     @default(150)
  audienceScope        AttendanceAudienceScope @default(TEAM)
  projectId            String?
  createdById          String
  verificationCode     String?
  codeWindowOpensAt    DateTime?
  codeWindowClosesAt   DateTime?
  createdAt            DateTime                @default(now())
  updatedAt            DateTime                @updatedAt

  project     Project?             @relation(fields: [projectId], references: [id], onDelete: SetNull)
  createdBy   User                 @relation("AttendanceEventCreator", fields: [createdById], references: [id], onDelete: Cascade)
  attendances AttendanceCheckIn[]
  categorySetting AttendanceEventCategorySetting?
  calendarSync AttendanceEventCalendarSync?
  availabilityPoll AttendanceEventAvailabilityPoll?
  availabilitySelections AttendanceEventAvailabilitySelection[]

  @@index([eventDate])
  @@index([projectId])
  @@index([createdById])
  @@index([audienceScope])
}

model AttendanceCheckIn {
  id                 String                       @id @default(cuid())
  eventId            String
  userId             String
  present            Boolean                      @default(true)
  verificationMethod AttendanceVerificationMethod
  codeVerified       Boolean                      @default(false)
  checkedInAt        DateTime                     @default(now())
  createdAt          DateTime                     @default(now())
  updatedAt          DateTime                     @updatedAt

  event AttendanceEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user  User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
  @@index([eventId])
  @@index([userId])
}

model AttendanceEventCategorySetting {
  eventId    String   @id
  category   String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  event AttendanceEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
}

model AttendanceEventCalendarSync {
  eventId                String   @id
  googleCalendarId       String
  googleCalendarEventId  String
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  event AttendanceEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
}

model AttendanceEventAvailabilityPoll {
  eventId      String   @id
  windowStart  DateTime
  windowEnd    DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  event AttendanceEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
}

model AttendanceEventAvailabilitySelection {
  eventId    String
  userId     String
  slotStart  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  event AttendanceEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user  User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([eventId, userId, slotStart])
  @@index([eventId])
  @@index([userId])
}

model When2MeetPoll {
  id          String   @id @default(cuid())
  title       String
  projectId   String
  createdById String
  /// Inclusive calendar first day shown as a grid column (`null` = legacy poll: weekday columns without dates).
  gridFirstDate DateTime? @db.Date
  gridLastDate  DateTime? @db.Date
  /// Minute-of-day `[0..1440)`, aligned to 15-minute steps. Inclusive interval `[slotStartMinute, slotEndMinute)`.
  slotStartMinute Int @default(540)
  slotEndMinute   Int @default(1020)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project       Project                   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdBy     User                      @relation("When2MeetPollCreator", fields: [createdById], references: [id], onDelete: Cascade)
  availabilities When2MeetAvailability[]

  @@index([projectId])
  @@index([createdById])
}

model When2MeetAvailability {
  id        String   @id @default(cuid())
  pollId    String
  userId    String
  slotIndex Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  poll When2MeetPoll @relation(fields: [pollId], references: [id], onDelete: Cascade)
  user User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([pollId, userId, slotIndex])
  @@index([pollId])
  @@index([userId])
}

model ProjectCalendarSetting {
  projectId               String   @id
  googleCalendarEmbedUrl  String?
  googleCalendarId        String?
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

enum AttendanceLocationType {
  IN_PERSON
  ONLINE
}

enum AttendanceAudienceScope {
  TEAM
  GLOBAL
}

enum AttendanceVerificationMethod {
  GEOFENCE
  CODE
}

// ============================================================================
// TASKS (Action items / Engagement tasks)
// ============================================================================

model Task {
  id            String       @id @default(cuid())
  taskName      String
  description   String?
  dueDate       DateTime
  projectName   String
  workstream    String
  workstreamId  String?      // For engagement page grouping
  status        TaskStatus   @default(PENDING)
  completed     Boolean      @default(false)
  createdById   String
  assigneeType  TaskAssigneeType
  assigneeEmail String?
  projectId     String?      // For ALL_TEAM: which project's members
  googleCalendarEventId String?
  googleCalendarId String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  createdBy User @relation(fields: [createdById], references: [id], onDelete: Cascade)

  @@index([createdById])
  @@index([dueDate])
  @@index([assigneeType])
  @@index([workstreamId])
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  OVERDUE
  COMPLETED
}

enum TaskAssigneeType {
  PERSON
  ALL
  ALL_PMS
  ALL_TEAM
}

// ============================================================================
// DELIVERABLES & SUBMISSIONS
// ============================================================================

model Deliverable {
  id          String            @id @default(cuid())
  projectId   String
  sprintId    String?
  assigneeId  String?
  title       String
  description String?
  type        DeliverableType
  templateKind DeliverableTemplateKind @default(CUSTOM)
  deadline    DateTime
  dueDateSource DueDateSource @default(AUTO)
  manualDeadlineUpdatedAt DateTime?
  assignedAt  DateTime?
  completed   Boolean @default(false)
  status      DeliverableStatus @default(PENDING)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  project     Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  sprint      Sprint?      @relation(fields: [sprintId], references: [id], onDelete: SetNull)
  assignee    User?        @relation("DeliverableAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  assignments DeliverableAssignment[]
  subtasks    DeliverableSubtask[]
  submissions Submission[]
  extensions  Extension[]

  @@index([projectId])
  @@index([sprintId])
  @@index([assigneeId])
  @@index([deadline])
  @@index([status])
}

model DeliverableSubtask {
  id            String   @id @default(cuid())
  deliverableId  String
  title         String
  notes         String?
  dueDate       DateTime?
  completed     Boolean  @default(false)
  assigneeId    String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  deliverable Deliverable @relation(fields: [deliverableId], references: [id], onDelete: Cascade)
  assignee   User?        @relation("DeliverableSubtaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)

  @@index([deliverableId])
  @@index([assigneeId])
  @@index([dueDate])
}

model DeliverableAssignment {
  id            String      @id @default(cuid())
  deliverableId String
  userId        String
  assignedAt    DateTime    @default(now())

  deliverable   Deliverable @relation(fields: [deliverableId], references: [id], onDelete: Cascade)
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([deliverableId, userId])
  @@index([deliverableId])
  @@index([userId])
}

model Sprint {
  id            String       @id @default(cuid())
  projectId      String
  sequenceNumber Int
  label          String
  weekStartDate  DateTime
  weekEndDate    DateTime
  status         SprintStatus @default(DRAFT)
  configSnapshot Json?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  project       Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  deliverables  Deliverable[]

  @@index([projectId])
  @@index([weekStartDate])
  @@unique([projectId, sequenceNumber])
}

enum SprintStatus {
  DRAFT
  RELEASED
}

enum DeliverableType {
  DOCUMENT
  PRESENTATION
  CODE
  ANALYSIS
  REPORT
  OTHER
}

enum DeliverableTemplateKind {
  INITIAL_SLIDES
  FINAL_SLIDES
  INITIAL_WHITEPAPER
  FINAL_WHITEPAPER
  CUSTOM
}

enum DueDateSource {
  AUTO
  MANUAL
}

enum DeliverableStatus {
  PENDING
  IN_PROGRESS
  SUBMITTED
  APPROVED
  OVERDUE
}

model Submission {
  id            String           @id @default(cuid())
  deliverableId String
  userId        String

  // File details (stored in Cloudflare R2/AWS S3)
  fileUrl  String
  fileName String
  fileSize Int // bytes
  mimeType String?

  // Review
  status       SubmissionStatus @default(PENDING_REVIEW)
  reviewedById String?
  reviewedAt   DateTime?
  feedback     String?

  // Versioning
  version    Int          @default(1)
  replacesId String?
  replaces   Submission?  @relation("SubmissionVersions", fields: [replacesId], references: [id], onDelete: SetNull)
  replacedBy Submission[] @relation("SubmissionVersions")

  // Timing
  submittedAt DateTime @default(now())
  isLate      Boolean  @default(false)

  deliverable Deliverable @relation(fields: [deliverableId], references: [id], onDelete: Cascade)
  submitter   User        @relation(fields: [userId], references: [id])
  reviewer    User?       @relation("SubmissionReviewer", fields: [reviewedById], references: [id])

  @@index([deliverableId])
  @@index([userId])
  @@index([status])
}

enum SubmissionStatus {
  PENDING_REVIEW
  APPROVED
  REJECTED
  REQUIRES_RESUBMISSION
}

// ============================================================================
// EXTENSION REQUESTS
// ============================================================================

model Extension {
  id               String          @id @default(cuid())
  deliverableId    String
  requestedById    String
  reason           String
  originalDueDate  DateTime
  requestedDueDate DateTime
  status           ExtensionStatus @default(PENDING)
  approvedById     String?
  approverNotes    String?
  requestedAt      DateTime        @default(now())
  respondedAt      DateTime?

  deliverable Deliverable @relation(fields: [deliverableId], references: [id], onDelete: Cascade)
  requester   User        @relation("ExtensionRequester", fields: [requestedById], references: [id])
  approver    User?       @relation("ExtensionReviewer", fields: [approvedById], references: [id])

  @@index([deliverableId])
  @@index([requestedById])
  @@index([status])
}

enum ExtensionStatus {
  PENDING
  APPROVED
  DENIED
  WITHDRAWN
}

// ============================================================================
// TIME TRACKING (Optional)
// ============================================================================

model TimeEntry {
  id          String   @id @default(cuid())
  userId      String
  projectId   String?
  date        DateTime
  hours       Float
  description String?
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([date])
}

// ============================================================================
// NOTIFICATIONS & BACKGROUND JOBS
// ============================================================================

model Notification {
  id        String              @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  message   String
  channel   NotificationChannel
  status    NotificationStatus  @default(PENDING)
  metadata  Json?               // Additional data (deliverable ID, project ID, etc.)
  sentAt    DateTime?
  createdAt DateTime            @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@index([type])
}

enum NotificationType {
  DEADLINE_REMINDER
  DEADLINE_24H
  DEADLINE_1H
  EXTENSION_REQUEST
  EXTENSION_APPROVED
  EXTENSION_DENIED
  SUBMISSION_APPROVED
  SUBMISSION_REJECTED
  PROJECT_ASSIGNED
  PROJECT_UPDATED
  OVERDUE_ALERT
}

enum NotificationChannel {
  SLACK
  EMAIL
  BOTH
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
  RETRYING
}

// ============================================================================
// SLACK INTEGRATIONS
// ============================================================================

enum SlackOAuthPurpose {
  INSTALL
  CONNECT
}

model SlackWorkspace {
  id                String   @id @default(cuid())
  teamId            String   @unique
  teamName          String?
  enterpriseId      String?
  botAccessToken    String
  installedByUserId String?
  installedAt       DateTime @default(now())
  updatedAt         DateTime @updatedAt

  installedBy User?                  @relation("SlackWorkspaceInstaller", fields: [installedByUserId], references: [id])
  oauthStates  SlackOAuthState[]
  connections  SlackUserConnection[]

  @@index([installedByUserId])
  @@index([enterpriseId])
}

model SlackOAuthState {
  id          String            @id @default(cuid())
  state       String            @unique
  userId      String
  purpose     SlackOAuthPurpose
  workspaceId String?
  redirectUri String?
  expiresAt   DateTime
  usedAt      DateTime?
  createdAt   DateTime          @default(now())

  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace SlackWorkspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([workspaceId])
  @@index([expiresAt])
}

model SlackUserConnection {
  id          String   @id @default(cuid())
  userId      String
  workspaceId String
  slackUserId String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace SlackWorkspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([userId, workspaceId])
  @@index([workspaceId])
  @@index([slackUserId])
}

// ============================================================================
// NEXT-AUTH TABLES
// ============================================================================

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
